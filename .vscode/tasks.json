{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Lucid: Backend (FastAPI)",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "uvicorn",
        "backend.main:app",
        "--reload",
        "--port",
        "8000"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "uvicorn",
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "line": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Started server process.*",
          "endsPattern": ".*Application startup complete.*"
        }
      },
      "presentation": {
        "panel": "dedicated",
        "group": "lucid",
        "reveal": "always",
        "focus": false,
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "Lucid: Frontend (Vite)",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "line": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*VITE.*",
          "endsPattern": ".*ready in.*"
        }
      },
      "presentation": {
        "panel": "dedicated",
        "group": "lucid",
        "reveal": "always",
        "focus": false,
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "Lucid: Start All",
      "dependsOrder": "parallel",
      "dependsOn": ["Lucid: Backend (FastAPI)", "Lucid: Frontend (Vite)"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Lucid: Stop All",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "foreach ($port in @(8000, 5173)) { $p = (Get-NetTCPConnection -LocalPort $port -ErrorAction SilentlyContinue).OwningProcess; if ($p) { Stop-Process -Id $p -Force -ErrorAction SilentlyContinue; Write-Host \"Stopped port $port\" } else { Write-Host \"Port $port not running\" } }"
      ],
      "presentation": {
        "panel": "shared",
        "reveal": "always",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Lucid: Install Frontend Deps",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "presentation": {
        "panel": "shared",
        "reveal": "always",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Lucid: Install Backend Deps",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "backend\\requirements.txt"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "panel": "shared",
        "reveal": "always",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Lucid: First-time Setup",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Lucid: Install Backend Deps",
        "Lucid: Install Frontend Deps"
      ],
      "problemMatcher": []
    }
  ]
}
